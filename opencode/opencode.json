{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "plan",
  "share": "manual",
  "lsp": false,
  "plugin": [
    "@slkiser/opencode-quota"
  ],
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "enabledProviders": [
        "openai",
        "opencode-go"
      ]
    }
  },
  "permission": {
    "*": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*credentials*": "deny",
      "*secret*": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "**/.gnupg/**": "deny",
      "**/.kube/**": "deny",
      "**/secrets/**": "deny",
      ".git/config": "deny"
    },
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*secret*": "deny"
    },
    "grep": "allow",
    "glob": "allow",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "wc *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch -a": "allow",
      "env": "deny",
      "printenv *": "deny",
      "export *": "deny",
      "cat *.env*": "deny",
      "cat *.key": "deny",
      "rm -rf *": "deny",
      "rm -r *": "deny",
      "ssh *": "deny",
      "curl *": "ask",
      "npm run check": "allow",
      "npx prettier *": "allow",
      "npm install *": "ask",
      "pip install *": "ask",
      "brew install *": "ask",
      "uv add *": "ask",
      "uv sync": "ask",
      "uv run *": "ask",
      "uv run pytest *": "allow",
      "uv run zajec *": "allow"
    },
    "webfetch": "allow",
    "external_directory": "ask",
    "tools": {
      "websearch": "allow"
    },
    "experimental": {
      "openTelemetry": "deny"
    }
  }
}
