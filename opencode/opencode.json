{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "plan",
  "share": "disabled",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*credentials*": "deny",
      "*secret*": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "**/.gnupg/**": "deny",
      "**/.kube/**": "deny",
      "**/secrets/**": "deny",
      ".git/config": "deny"
    },
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*secret*": "deny"
    },
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "env": "deny",
      "printenv *": "deny",
      "export *": "deny",
      "cat *.env*": "deny",
      "cat *.key": "deny",
      "rm -rf *": "deny",
      "rm -r *": "deny",
      "ssh *": "deny",
      "curl *": "ask",
      "npm install *": "ask",
      "pip install *": "ask",
      "brew install *": "ask",
      "uv add *": "ask",
      "uv sync": "ask"
    },
    "webfetch": "ask",
    "external_directory": "ask",
    "tools": {
      "websearch": "allow"
    },
    "experimental": {
      "openTelemetry": "deny"
    }
  }
}
